{
  "name": "trust-lattice",
  "version": "0.1.0",
  "description": "Evidence-weighted trust graph that gates multi-agent actions — MCP-native",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "trust-lattice": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "policies",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod 755 dist/cli.js dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --max-warnings 0",
    "seed": "tsx src/cli.ts seed",
    "serve": "tsx src/cli.ts serve",
    "dev": "npm run seed -- --force && vite --config dashboard/vite.config.ts",
    "dev:dashboard": "vite --config dashboard/vite.config.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "trust",
    "multi-agent",
    "reputation",
    "gate"
  ],
  "author": "SanjoyDat1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SanjoyDat1/trust-lattice.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "better-sqlite3": "^11.10.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "eslint": "^9.30.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}
